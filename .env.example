# ===== 运行环境 =====
# APP_HOST: API 监听地址，本地运行可用 127.0.0.1，Docker/反代场景改成 0.0.0.0
APP_HOST=127.0.0.1
# PORT: 后端容器监听端口
PORT=8080
# TZ: 容器时区
TZ=Asia/Shanghai
# APP_TIMEZONE: 面板调度时区，默认继承 TZ；如需单独覆盖可设置
# APP_TIMEZONE=Asia/Shanghai
# 数据目录默认使用 /data；如需修改请在 UI -> 系统设置 -> 数据目录 中设置
# APP_DATA_DIR_OVERRIDE_FILE: 数据目录覆盖文件位置，高级选项
# APP_DATA_DIR_OVERRIDE_FILE=.tg_signpulse_data_dir
# APP_DB_PATH: SQLite 数据库文件路径，高级选项
# APP_DB_PATH=/data/db.sqlite
# APP_SIGNER_WORKDIR: 签到任务工作目录，高级选项
# APP_SIGNER_WORKDIR=/data/.signer
# APP_SESSION_DIR: Telegram session 存储目录，高级选项
# APP_SESSION_DIR=/data/sessions
# APP_LOGS_DIR: 应用日志目录，高级选项
# APP_LOGS_DIR=/data/logs

# ===== 安全与登录 =====
# APP_APP_NAME: 面板应用名称
# APP_APP_NAME=tg-signer-panel
# APP_SECRET_KEY: 必填，建议使用随机字符串
# 例如: python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_SECRET_KEY=your_secret_key_here
# APP_ACCESS_TOKEN_EXPIRE_HOURS: 登录令牌有效期（小时），默认 12
# APP_ACCESS_TOKEN_EXPIRE_HOURS=12
# ADMIN_USERNAME / ADMIN_PASSWORD: 初始管理员账号，仅在首次创建用户表为空时生效
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change_me
# APP_TOTP_VALID_WINDOW: 2FA TOTP 时间窗口容差，默认 0
# APP_TOTP_VALID_WINDOW=1

# ===== Telegram / Pyrogram =====
# TG_API_ID / TG_API_HASH: Telegram API 凭证；如需自己的凭证，请从 https://my.telegram.org 获取
# 初次启动时，如果 UI 还没有保存过 Telegram API 配置，会先使用环境变量
# 一旦在 UI -> 系统设置 -> Telegram API 配置 中保存新值，运行时优先使用 UI 配置
# TG_API_ID=123456
# TG_API_HASH=your_api_hash_here
# TG_PROXY: 共享代理地址，例如 socks5://127.0.0.1:1080
# TG_PROXY=socks5://127.0.0.1:1080
# TG_DEVICE_MODEL: 设备型号，默认 Samsung Galaxy S24
# TG_DEVICE_MODEL=Samsung Galaxy S24
# TG_SYSTEM_VERSION: 系统版本，默认 SDK 35
# TG_SYSTEM_VERSION=SDK 35
# TG_APP_VERSION: 应用版本，默认 11.4.2
# TG_APP_VERSION=11.4.2
# TG_LANG_CODE: 语言代码，默认 zh
# TG_LANG_CODE=zh
# TG_SESSION_MODE: file 或 string，默认 file
# TG_SESSION_MODE=file
# TG_SESSION_NO_UPDATES: 1 表示关闭更新接收；TG_NO_UPDATES 为兼容别名
# TG_SESSION_NO_UPDATES=0
# TG_NO_UPDATES=0
# TG_GLOBAL_CONCURRENCY: 全局并发数，默认 1
# TG_GLOBAL_CONCURRENCY=1

# ===== 签到 / 任务调度 =====
# SIGN_TASK_ACCOUNT_COOLDOWN: 同账号任务冷却秒数，默认 5
# SIGN_TASK_ACCOUNT_COOLDOWN=5
# SIGN_TASK_FORCE_IN_MEMORY: 1 表示强制内存模式
# SIGN_TASK_FORCE_IN_MEMORY=0
# SIGN_TASK_HISTORY_MAX_ENTRIES: 单任务历史条数上限，默认 100
# SIGN_TASK_HISTORY_MAX_ENTRIES=100
# SIGN_TASK_HISTORY_MAX_FLOW_LINES: 单次日志流保留行数上限，默认 200
# SIGN_TASK_HISTORY_MAX_FLOW_LINES=200
# SIGN_TASK_HISTORY_MAX_LINE_CHARS: 单行日志字符上限，默认 500
# SIGN_TASK_HISTORY_MAX_LINE_CHARS=500
# SIGN_TASK_HISTORY_MAX_MESSAGE_EVENTS: 单次执行保留的结构化消息事件上限，默认 100；设为 0 时禁用历史保留
# SIGN_TASK_HISTORY_MAX_MESSAGE_EVENTS=100

# ===== AI 配置 =====
# AI 配置现统一在 UI -> 系统设置 -> AI 配置 中设置
# CLI 场景可通过 tg-signer llm-config 写入同一份持久化配置文件

# ===== 前端构建变量 =====
# NEXT_PUBLIC_API_BASE: 前端请求 API 的基础路径，默认 /api
# NEXT_PUBLIC_API_BASE=/api

# ===== 面板 / CLI 辅助变量 =====
# TG_SIGNER_WORKDIR: 工作目录，默认 .signer
# TG_SIGNER_WORKDIR=.signer
# TG_ACCOUNT: 当前账号
# TG_ACCOUNT=my_account
# TG_SESSION_STRING: 字符串会话
# TG_SESSION_STRING=...
# TG_SIGNER_GUI_AUTHCODE: GUI 授权码
# TG_SIGNER_GUI_AUTHCODE=...
# SERVER_CHAN_SEND_KEY: 服务器推送密钥
# SERVER_CHAN_SEND_KEY=...

# ===== 日志 =====
# PYROGRAM_LOG_ON: 1 表示开启 Pyrogram 日志
# PYROGRAM_LOG_ON=0
